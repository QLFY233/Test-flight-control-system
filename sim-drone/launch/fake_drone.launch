<?xml version="1.0"?>
<launch>
  <!--
    Fake Drone Simulator Launch File

    Starts the fake drone node for testing Backend B without a
    real drone or PX4 SITL.

    Parameters:
      max_speed: Maximum drone speed in m/s (default: 2.0)
      setpoint_timeout: Time in seconds before hovering if no
                        setpoint received (default: 0.5)
      boundary_x: Field X boundary [min, max] (default: [0, 5])
      boundary_y: Field Y boundary [min, max] (default: [0, 4])
      boundary_z: Field Z boundary [min, max] (default: [0, 3])
      position_noise_std: Position noise std dev in meters (default: 0.01)
      publish_rate: Publishing frequency in Hz (default: 50)
  -->
  <node name="fake_drone" pkg="sim_drone" type="fake_drone_node.py" output="screen">
    <param name="max_speed" value="2.0"/>
    <param name="setpoint_timeout" value="0.5"/>
    <param name="boundary_x" value="[0.0, 5.0]"/>
    <param name="boundary_y" value="[0.0, 4.0]"/>
    <param name="boundary_z" value="[0.0, 3.0]"/>
    <param name="position_noise_std" value="0.01"/>
    <param name="publish_rate" value="50.0"/>
  </node>
</launch>
